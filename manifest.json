{
  "manifest_version": 3,
  "name": "Status Window",
  "description": "A cozy study and work tracker with stats, sessions, and Supabase sync.",
  "version": "0.1.0",
  "action": {
    "default_title": "Status Window",
    "default_popup": "dist/popup.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  },
  "permissions": ["storage", "identity", "alarms", "sidePanel", "offscreen"],
  "host_permissions": ["https://bbqkxxcuufbcegdqzony.supabase.co/*"],
  "icons": {
    "16": "dist/icons/icon-16.png",
    "32": "dist/icons/icon-32.png",
    "48": "dist/icons/icon-48.png",
    "128": "dist/icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://bbqkxxcuufbcegdqzony.supabase.co wss://bbqkxxcuufbcegdqzony.supabase.co;"
  }
}
