{
  "manifest_version": 3,
  "name": "Status Window",
  "description": "A cozy study and work tracker with stats, sessions, and Supabase sync.",
  "version": "0.1.0",
  "action": {
    "default_title": "Status Window",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["storage", "identity", "alarms", "sidePanel", "offscreen"],
  "host_permissions": ["https://*.supabase.co/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/*.wav", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co;"
  }
}
